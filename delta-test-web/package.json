{
  "name": "delta-test-web",
  "version": "1.0.0-SNAPSHOT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write src/",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "api:generate": "openapi-typescript http://localhost:8080/v3/api-docs -o src/api/types.generated.ts",
    "api:generate:local": "openapi-typescript ../delta-test-server/delta-test-admin/src/main/resources/openapi.json -o src/api/types.generated.ts"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "ant-design-vue": "^4.2.6",
    "axios": "^1.9.0",
    "dayjs": "^1.11.13",
    "pinia": "^2.3.1",
    "vue": "^3.5.17",
    "vue-router": "^4.5.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "esbuild",
      "vue-demi"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/eslint-config-typescript": "^14.5.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.28.0",
    "eslint-plugin-vue": "^10.2.0",
    "jsdom": "^26.1.0",
    "less": "^4.3.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.5.3",
    "typescript": "~5.8.3",
    "unplugin-auto-import": "^19.2.0",
    "unplugin-vue-components": "^28.7.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.10"
  }
}
