# ============================================================
# TRAE 索引忽略规则 / TRAE Indexing Ignore Rules
# ============================================================
# 本文件作为 .gitignore 的补充，指定 TRAE 在索引仓库时额外忽略的文件。
# This file supplements .gitignore, specifying additional files to ignore during TRAE indexing.
# ============================================================

# ==================== Java 后端 / Java Backend ====================
# Maven 构建产物 / Maven build artifacts
*target/

# ==================== Vue 前端 / Vue Frontend ====================
# 依赖目录 / Dependencies
node_modules/

# 构建产物 / Build artifacts
dist/
dist-ssr/

# Vite 缓存 / Vite cache
.vite/

# 自动生成的类型声明 / Auto-generated type declarations
src/components.d.ts
src/auto-imports.d.ts

# ==================== Python AI 服务 / Python AI Service ====================
# 虚拟环境 / Virtual environments
.venv/
venv/
ENV/

# 字节码缓存 / Bytecode cache
__pycache__/
*.py[cod]
*$py.class

# 工具缓存 / Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# 覆盖率报告 / Coverage reports
.coverage
htmlcov/

# ==================== C 计算引擎 / C Engine ====================
# CMake 构建目录 / CMake build directories
build/
Build/
out/
cmake-build-debug/
cmake-build-release/
cmake-build-verify/

# Conan 生成与缓存 / Conan generated files and cache
generated/
.conan2/

# CMake 缓存 / CMake cache
CMakeCache.txt
CMakeFiles/
cmake_install.cmake

# 编译产物 / Compilation artifacts
*.o
*.obj
*.a
*.lib
*.so
*.dll
*.exe

# ==================== 通用 / General ====================
# 日志文件 / Log files
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# 编辑器 / Editors
.idea/
.vscode/
*.swp
*.swo
*~

# 系统文件 / System files
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 本地环境配置 / Local environment configs
*.local
.env.local
.env.*.local

# Python 包元数据 / Python package metadata
*.egg-info/
*.egg

# ==================== TRAE 自身 / TRAE Itself ====================
# TRAE 配置目录无需索引 / TRAE config directory no need to index
.trae/
/exercise/
